{
  "name": "pi-pai",
  "version": "4.2.0",
  "description": "Personal AI Infrastructure extension for Pi — full v4.0.3 sync: ISC splitting test, count gates, anti-criteria, capability tracking, time budgets, enhanced observability, agent personas, sentiment tracking, self-evolution, Ralph iteration, damage control",
  "type": "module",
  "main": "src/extension.ts",
  "pi": {
    "extensions": [
      "src/extension.ts"
    ],
    "commands": [
      "status"
    ],
    "tools": [
      "pai_status",
      "pai_learn",
      "pai_rate"
    ]
  },
  "scripts": {
    "build": "tsc",
    "test": "pi -e src/extension.ts -p \"say hello and list your /commands and tools\"",
    "test:old": "echo \"Legacy tests\""
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pai",
    "personal-ai-infrastructure",
    "telos",
    "ralph-wiggum",
    "damage-control",
    "goal-tracking",
    "learning-loop",
    "scientific-method"
  ],
  "author": "arosstale",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arosstale/pi-pai.git"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.50.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
